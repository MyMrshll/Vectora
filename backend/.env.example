# FastAPI Settings
PROJECT_NAME="Vectora API"
DEBUG=true

# Supabase Configurations
# Dapatkan di Project Settings -> API
SUPABASE_URL=your-supabase-project-url
SUPABASE_KEY=your-supabase-anon-key
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Qdrant Configurations
# Use "http://localhost:6333" for local docker or Qdrant Cloud URL.
# Use ":memory:" for transient in-memory development (requires qdrant-client).
QDRANT_URL=:memory:
QDRANT_API_KEY=your-qdrant-api-key

# Google Gemini Configurations
GEMINI_API_KEY=your-gemini-api-key
